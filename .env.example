# Martian AI - Environment Configuration Example
# Copy this to .env and adjust values as needed

# Backend Configuration
DATABASE_URL=sqlite:///./martian_ai.db
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_TITLE=Martian AI API
API_VERSION=1.0.0

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=production

# Optional: OpenAI API (if using advanced features)
# OPENAI_API_KEY=your-api-key

# Optional: Database (for PostgreSQL in production)
# DATABASE_URL=postgresql://user:password@postgres:5432/martian_ai

# Optional: File upload limits
# MAX_FILE_SIZE_MB=1
# MAX_UPLOAD_SIZE_MB=50

# Logging
LOG_LEVEL=INFO
